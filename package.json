{
  "name": "wizmap-monorepo",
  "version": "0.1.7",
  "private": true,
  "scripts": {
    "install": "cd frontend && npm install",
    "dev": "cd frontend && npm run dev -- --port 3002",
    "dev:frontend": "cd frontend && npm run dev -- --port 3002",
    "dev:backend": "cd backend && python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 8080",
    "build": "cd frontend && npm run build",
    "build:github": "cd frontend && npm run build:github",
    "build:vercel": "cd frontend && npm run build:vercel",
    "build:notebook": "cd frontend && npm run build:notebook",
    "preview": "cd frontend && npm run preview",
    "check": "cd frontend && npm run check",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d",
    "docker:build": "docker compose -f docker-compose.yml -f docker-compose.dev.yml build",
    "docker:logs": "docker compose -f docker-compose.yml -f docker-compose.dev.yml logs -f",
    "docker:stop": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down"
  },
  "description": "WizMap - Visualization of high-dimensional data",
  "keywords": ["visualization", "dimensionality-reduction", "embeddings"],
  "author": "",
  "license": "MIT"
}
