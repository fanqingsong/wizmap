# Application Settings
APP_NAME=WizMap Backend
APP_VERSION=0.1.0
DEBUG=True

# Server Settings
HOST=0.0.0.0
PORT=8000

# Database Settings
DATABASE_URL=postgresql://wizmap:wizmap@postgres:5432/wizmap

# Redis Settings
REDIS_URL=redis://redis:6379/0

# MinIO Settings
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=wizmap-uploads
MINIO_SECURE=False

# Processing Settings
MAX_FILE_SIZE_MB=100
EMBEDDING_DIM=384

# Embedding API (SiliconFlow / 硅基流动, OpenAI-compatible)
# Required: set EMBEDDING_API_KEY to enable dataset processing.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_BATCH_SIZE=32
EMBEDDING_TIMEOUT=60

# Celery Settings
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# CORS Settings
CORS_ORIGINS=["http://localhost:3001","http://localhost:3000"]
