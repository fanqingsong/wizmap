#!/bin/bash

# WizMap Logs Viewer Script
# Shows logs from running services

set -e

echo "📋 WizMap Service Logs"
echo "=========================================="

# Check if Docker is running
if ! docker info > /dev/null 2>&1; then
    echo "❌ Error: Docker is not running."
    exit 1
fi

# Change to project root directory
cd "$(dirname "$0")/.."

# Check if services are running
if ! docker compose ps | grep -q "Up"; then
    echo "❌ No services are currently running."
    echo ""
    echo "💡 Start services first:"
    echo "  Development: ./bin/start_dev.sh"
    echo "  Production: ./bin/start_prod.sh"
    exit 1
fi

echo "🔍 Following logs from all services..."
echo "Press Ctrl+C to stop viewing logs"
echo ""

# Determine which configuration to use
if docker compose -f docker-compose.yml -f docker-compose.dev.yml ps 2>/dev/null | grep -q "wizmap-frontend-dev.*Up"; then
    # Development mode
    docker compose -f docker-compose.yml -f docker-compose.dev.yml logs -f
else
    # Production mode
    docker compose logs -f
fi
